# ============================================================================
# MOCK DATA (tạm bỏ qua BE cho các service, trừ identity & gateway)
# true  = dùng dữ liệu giả trong src/mocks/ (xem UI có data ngay, KHÔNG cần BE)
# false = gọi API thật như bình thường
# Vẫn cần chạy identity BE thật để đăng nhập (identity KHÔNG bị mock).
VITE_USE_MOCK=true
# (tuỳ chọn) độ trễ giả lập mỗi request, ms
VITE_MOCK_DELAY=220

# Use Gateway (true: call via YARP Gateway, false: call direct services)
# Bật Gateway để tránh phải đồng bộ tay port thật của từng service (đã đúng
# port trong appsettings.json của Gateway) và tránh lỗi CORS khi gọi trực tiếp.
VITE_USE_GATEWAY=true

# Gateway URL (YARP)
VITE_API_GATEWAY_URL=http://localhost:5088

# Direct Service URLs (Fallback / Direct Call — chỉ dùng khi VITE_USE_GATEWAY=false)
# Identity có Kestrel override trong appsettings.json -> REST thật chạy ở
# https://localhost:5001 (KHÔNG PHẢI 5285 của launchSettings).
VITE_IDENTITY_SERVICE_URL=https://localhost:5001
VITE_PROFILE_SERVICE_URL=http://localhost:5138
VITE_JOB_SERVICE_URL=http://localhost:5103
VITE_PROJECT_SERVICE_URL=http://localhost:5003
VITE_MARKETPLACE_SERVICE_URL=http://localhost:5253
VITE_REVIEW_SERVICE_URL=http://localhost:5290
VITE_NOTIFICATION_SERVICE_URL=http://localhost:5295
VITE_MESSAGING_SERVICE_URL=http://localhost:5200
VITE_AI_SERVICE_URL=http://localhost:5092
VITE_FILE_SERVICE_URL=http://localhost:5110
